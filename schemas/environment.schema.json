{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/python-framework-analysis-pipeline/environment.schema.json",
  "title": "Environment",
  "description": "Project-level environment configuration defining platforms, software versions, host references, and capabilities.",
  "type": "object",
  "required": ["schemaVersion", "framework", "mode", "platforms", "software"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "framework": {
      "type": "string",
      "minLength": 1,
      "description": "Framework adapter ID, e.g. pyflink, pyspark."
    },
    "mode": {
      "type": "string",
      "enum": ["plan-only", "full-auto", "manual-record"],
      "description": "Execution mode. First version only supports plan-only and manual-record."
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "arch", "hosts"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Platform identifier, e.g. arm, x86."
          },
          "arch": {
            "type": "string",
            "enum": ["aarch64", "x86_64"],
            "description": "CPU architecture."
          },
          "hosts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["role", "hostRef"],
              "additionalProperties": false,
              "properties": {
                "role": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Framework-specific host role, e.g. client, jobmanager, taskmanager."
                },
                "hostRef": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Reference to a key in hostRefs."
                }
              }
            }
          }
        }
      }
    },
    "software": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flinkImage": {
          "type": "string",
          "description": "Flink Docker image, e.g. flink:2.2.0-java17."
        },
        "dockerRequired": {
          "type": "boolean",
          "default": false
        },
        "clusterTopology": {
          "type": "string",
          "description": "Cluster layout, e.g. 1jm-2tm."
        },
        "containerNetwork": {
          "type": "string",
          "description": "Docker network name for the cluster."
        },
        "pythonVersion": {
          "type": "string",
          "description": "Required Python version (only for non-container deployments)."
        },
        "frameworkVersion": {
          "type": "string",
          "description": "Framework version or source revision."
        },
        "dependencyLock": {
          "type": "string",
          "description": "Path to a dependency lock file."
        },
        "profilingTools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["perf", "strace", "objdump", "gdb", "readelf", "py-spy"]
          },
          "description": "Performance profiling tools to install in the environment.",
          "default": []
        },
        "pythonFlamegraph": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "rate": {
              "type": "integer",
              "description": "py-spy sample rate in Hz.",
              "default": 100
            },
            "subprocesses": {
              "type": "boolean",
              "description": "Follow child Python processes when recording.",
              "default": true
            }
          }
        },
        "pythonImage": {
          "type": "string",
          "description": "Base Python Docker image for single-container benchmark frameworks."
        },
        "dockerRegistry": {
          "type": "string",
          "description": "Optional registry prefix for base images."
        },
        "aptMirror": {
          "type": "string",
          "description": "Optional Debian apt mirror URL."
        },
        "aptSecurityMirror": {
          "type": "string",
          "description": "Optional Debian security apt mirror URL."
        },
        "pipIndexUrl": {
          "type": "string",
          "description": "Optional pip index URL."
        },
        "pipExtraIndexUrl": {
          "type": "string",
          "description": "Optional pip extra index URL."
        },
        "pipTrustedHosts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "pip trusted-host entries."
        },
        "pipTimeout": {
          "type": "integer",
          "description": "pip timeout in seconds."
        },
        "pipRetries": {
          "type": "integer",
          "description": "pip retry count."
        },
        "pySpyVersion": {
          "type": "string",
          "description": "Optional py-spy version pin."
        },
        "hfEndpoint": {
          "type": "string",
          "description": "Optional Hugging Face endpoint/mirror."
        },
        "dataJuicerVersion": {
          "type": "string",
          "description": "Data-Juicer package version."
        },
        "dataJuicerImage": {
          "type": "string",
          "description": "Fallback Data-Juicer Docker image."
        },
        "dataJuicerImages": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Platform-specific Data-Juicer Docker images."
        },
        "dataJuicerContainer": {
          "type": "string",
          "description": "Data-Juicer benchmark container name."
        },
        "benchmarkDataUrl": {
          "type": "string",
          "description": "Data-Juicer benchmark data archive URL."
        },
        "benchmarkDataMirrorUrl": {
          "type": "string",
          "description": "Optional Data-Juicer benchmark data mirror URL."
        },
        "benchmarkTextDataUrl": {
          "type": "string",
          "description": "Optional Data-Juicer text-only benchmark data URL."
        },
        "benchmarkUseFullArchive": {
          "type": "boolean",
          "description": "Whether to download and use the full benchmark archive."
        },
        "benchmarkTextRows": {
          "type": "integer",
          "description": "Synthetic text row count for Data-Juicer text-only benchmark."
        },
        "benchmarkModalities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Benchmark modalities."
        },
        "dataJuicerCacheHome": {
          "type": "string",
          "description": "Data-Juicer cache home inside the container."
        },
        "dataJuicerModelsCache": {
          "type": "string",
          "description": "Data-Juicer model cache directory inside the container."
        },
        "dataJuicerAssetsCache": {
          "type": "string",
          "description": "Data-Juicer assets cache directory inside the container."
        },
        "udfBenchmarkingRepo": {
          "type": "string",
          "description": "UDF_Benchmarking git repository URL."
        },
        "udfBenchmarkingRevision": {
          "type": "string",
          "description": "Optional UDF_Benchmarking git revision."
        },
        "udfBenchmarkingImage": {
          "type": "string",
          "description": "Fallback UDF_Benchmarking Docker image."
        },
        "udfBenchmarkingImages": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Platform-specific UDF_Benchmarking Docker images."
        },
        "udfBenchmarkingContainer": {
          "type": "string",
          "description": "UDF_Benchmarking benchmark container name."
        },
        "benchmarkName": {
          "type": "string",
          "description": "Benchmark case name to run and collect."
        },
        "benchmarkConfigFile": {
          "type": "string",
          "description": "Config file path relative to the benchmark workload directory."
        },
        "benchmarkTimeout": {
          "type": "integer",
          "description": "Benchmark timeout in seconds."
        }
      }
    },
    "hostRefs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["connect"],
        "additionalProperties": false,
        "properties": {
          "connect": {
            "type": "string",
            "enum": ["ssh", "local"],
            "description": "Connection method."
          },
          "alias": {
            "type": "string",
            "description": "SSH config Host alias, if pre-configured."
          },
          "user": {
            "type": "string",
            "minLength": 1
          },
          "addressRef": {
            "type": "string",
            "description": "Secret reference for host address."
          },
          "secretRef": {
            "type": "string",
            "description": "Secret reference for authentication credentials."
          },
          "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ssh": { "type": "boolean", "default": false },
              "sudo": { "type": "boolean", "default": false },
              "docker": { "type": "boolean", "default": false },
              "internet": { "type": "boolean", "default": false },
              "internalMirror": { "type": "boolean", "default": false },
              "upload": { "type": "boolean", "default": false },
              "download": { "type": "boolean", "default": false }
            }
          }
        }
      }
    }
  }
}
