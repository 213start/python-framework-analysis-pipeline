{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/python-framework-analysis-pipeline/acquisition-manifest.schema.json",
  "title": "AcquisitionManifest",
  "description": "Master manifest for data acquisition artifacts in a single run directory.",
  "type": "object",
  "required": ["schemaVersion", "projectId", "platform", "runDir", "timing", "perf", "asm"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1,
      "description": "Project identifier matching project.yaml id."
    },
    "platform": {
      "type": "string",
      "minLength": 1,
      "description": "Platform identifier, e.g. arm, x86."
    },
    "runDir": {
      "type": "string",
      "minLength": 1,
      "description": "Relative path to the run directory from project root."
    },
    "collectedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of when acquisition was performed."
    },
    "provenance": {
      "type": "object",
      "description": "Provenance metadata about the acquisition process.",
      "properties": {
        "timingSource": { "type": "string" },
        "perfToolVersion": { "type": "string" },
        "recordedBy": { "type": "string" }
      }
    },
    "timing": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "collected", "failed", "skipped"],
          "description": "Collection status for timing data."
        },
        "cases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of case IDs (query names) collected."
        },
        "files": {
          "type": "object",
          "properties": {
            "raw": { "type": "string", "description": "Path to timing-raw.json." },
            "normalized": { "type": "string", "description": "Path to timing-normalized.json." }
          }
        }
      }
    },
    "perf": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "collected", "failed", "skipped"],
          "description": "Collection status for perf profile data."
        },
        "files": {
          "type": "object",
          "properties": {
            "categories": { "type": "string" },
            "hotspots": { "type": "string" },
            "ipHotspots": { "type": "string" }
          }
        }
      }
    },
    "asm": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "collected", "failed", "skipped"],
          "description": "Collection status for machine code data."
        },
        "hotspotCount": {
          "type": "integer",
          "description": "Number of annotated hotspot functions."
        },
        "filesPattern": {
          "type": "string",
          "description": "Glob pattern for assembly files, e.g. asm/arm64/*.s."
        },
        "objdumpFiles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of objdump output files."
        }
      }
    }
  }
}
